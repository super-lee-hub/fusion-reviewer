          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "rationale": {
          "default": "",
          "title": "Rationale",
          "type": "string"
        },
        "schema_version": {
          "default": "1.0.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "concern_id"
      ],
      "title": "RevisionAssessment",
      "type": "object"
    }
  },
  "description": "Aggregate revision response review (host-agent-produced).",
