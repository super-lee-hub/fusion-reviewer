    "summary": {
      "default": "",
      "title": "Summary",
      "type": "string"
    },
    "quality_assessment": {
      "default": "",
      "title": "Quality Assessment",
      "type": "string"
    },
    "markdown": {
      "default": "",
      "title": "Markdown",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    }
