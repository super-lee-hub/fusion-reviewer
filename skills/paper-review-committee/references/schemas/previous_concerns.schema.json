        "medium",
        "high",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    },
    "status_from_previous": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Status From Previous"
    }
  },
  "required": [
    "id",
    "issue_key",
    "title"
  ],
  "title": "PreviousConcern",
  "type": "object"
