  "properties": {
    "id": {
      "title": "Id",
      "type": "string"
    },
    "issue_key": {
      "title": "Issue Key",
      "type": "string"
    },
    "title": {
      "title": "Title",
      "type": "string"
    },
    "description": {
      "default": "",
      "title": "Description",
      "type": "string"
    },
    "severity": {
      "default": "medium",
      "enum": [
