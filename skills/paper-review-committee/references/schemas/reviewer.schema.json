{
  "$defs": {
    "EvidenceRef": {
      "properties": {
        "page": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Page"
        },
        "start_line": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start Line"
        },
        "end_line": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Line"
        },
        "quote": {
          "default": "",
          "title": "Quote",
          "type": "string"
        },
        "locator": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Locator"
        },
        "image_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Image Path"
        }
      },
      "title": "EvidenceRef",
      "type": "object"
    },
    "Finding": {
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "issue_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Issue Key"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "category": {
          "title": "Category",
          "type": "string"
        },
        "severity": {
          "default": "medium",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ],
          "title": "Severity",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "needs_external_verification": {
          "default": false,
          "title": "Needs External Verification",
          "type": "boolean"
        },
        "recommendation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Recommendation"
        },
        "origin": {
          "default": "original",
          "enum": [
            "original",
            "new_after_revision"
          ],
          "title": "Origin",
          "type": "string"
        }
      },
      "required": [
        "id",
        "title",
        "description",
        "category"
      ],
      "title": "Finding",
      "type": "object"
    }
  },
  "properties": {
    "agent_id": {
      "title": "Agent Id",
      "type": "string"
    },
    "kind": {
      "enum": [
        "generalist",
        "specialist",
        "editor"
      ],
      "title": "Kind",
      "type": "string"
    },
    "title": {
      "title": "Title",
      "type": "string"
    },
    "provider_profile": {
      "default": "",
      "title": "Provider Profile",
      "type": "string"
    },
    "model": {
      "default": "",
      "title": "Model",
      "type": "string"
    },
    "review_source": {
      "default": "unknown",
      "enum": [
        "subagent",
        "serial_local",
        "local",
        "unknown"
      ],
      "title": "Review Source",
      "type": "string"
    },
    "agent_host": {
      "default": "unknown",
      "enum": [
        "codex",
        "claude_code",
        "other",
        "unknown"
      ],
      "title": "Agent Host",
      "type": "string"
    },
    "status": {
      "default": "completed",
      "enum": [
        "completed",
        "failed"
      ],
      "title": "Status",
      "type": "string"
    },
    "summary": {
      "default": "",
      "title": "Summary",
      "type": "string"
    },
    "strengths": {
      "items": {
        "type": "string"
      },
      "title": "Strengths",
      "type": "array"
    },
    "weaknesses": {
      "items": {
        "type": "string"
      },
      "title": "Weaknesses",
      "type": "array"
    },
    "recommendation": {
      "default": "major_revision",
      "enum": [
        "accept",
        "minor_revision",
        "major_revision",
        "reject"
      ],
      "title": "Recommendation",
      "type": "string"
    },
    "findings": {
      "items": {
        "$ref": "#/$defs/Finding"
      },
      "title": "Findings",
      "type": "array"
    },
    "markdown": {
      "default": "",
      "title": "Markdown",
      "type": "string"
    },
    "error": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Error"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    }
  },
  "required": [
    "agent_id",
    "kind",
    "title"
  ],
  "title": "AgentReview",
  "type": "object"
}
