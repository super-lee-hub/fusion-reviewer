# =========================
# 核心路径
# =========================
# 所有运行产物默认写到 review_outputs/<paper_stem>/<run_id>/
DATA_DIR=./review_outputs
DEEPREVIEW_ROOT=../DeepReviewer-v2
PROVIDERS_FILE=./providers.yaml
REVIEW_PLAN_FILE=./review_plan.yaml
ROLES_FILE=./roles.yaml

# =========================
# 文档预处理
# =========================
# PDF 默认优先走 MinerU。
# DOCX / DOC 默认先尝试 LibreOffice -> PDF，再走 PDF 预处理。
MINERU_BASE_URL=https://mineru.net/api/v4
MINERU_API_TOKEN=
MINERU_MODEL_VERSION=vlm
MINERU_UPLOAD_ENDPOINT=/file-urls/batch
MINERU_POLL_ENDPOINT_TEMPLATES=/extract-results/batch/{batch_id},/extract-results/{batch_id},/extract/task/{batch_id}
MINERU_POLL_INTERVAL_SECONDS=3
MINERU_POLL_TIMEOUT_SECONDS=900
MINERU_REQUEST_MAX_RETRIES=2
MINERU_RETRY_BACKOFF_SECONDS=1.5
ALLOW_LOCAL_PARSE_FALLBACK=true
PREPROCESS_CACHE_DIRNAME=_normalize_cache
ENABLE_PAGE_SNAPSHOTS=true
MAX_SNAPSHOT_PAGES=8

# 如果当前网络必须走代理访问外网，可以配置系统环境变量 HTTPS_PROXY / HTTP_PROXY。
# MinerU 请求会继承系统代理环境，不需要额外的项目内专用代理参数。

# 如果系统没有自动找到 soffice.exe，可以手动指定。
LIBREOFFICE_BIN=

# =========================
# 可选的外部论文检索
# =========================
PAPER_SEARCH_ENABLED=false
PAPER_SEARCH_BASE_URL=
PAPER_SEARCH_API_KEY=
PAPER_SEARCH_ENDPOINT=/pasa/search
PAPER_SEARCH_HEALTH_ENDPOINT=/health

# =========================
# Provider 的 API key / base URL
# =========================
# 如果暂时不用某个 provider，对应值留空即可。
OPENAI_API_KEY=
OPENAI_BASE_URL=

AIHUBMIX_API_KEY=
AIHUBMIX_BASE_URL=

SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=

ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# =========================
# Web 与运行时设置
# =========================
WEB_HOST=127.0.0.1
WEB_PORT=8123
DEFAULT_WAIT_SECONDS=8
MAX_EVIDENCE_CHARS=120000
FORCE_ENGLISH_OUTPUT=false
ATTACH_SOURCE_PDF_APPENDIX=false
